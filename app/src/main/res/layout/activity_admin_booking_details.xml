<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurfaceContainerLowest"
    android:padding="24dp"
    tools:context=".AdminBookingDetailsActivity">

    <TextView
        android:id="@+id/tvBookingDetailsTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:layout_centerHorizontal="true"
        android:text="Booking Request Details"
        android:textAppearance="@style/TextAppearance.Material3.HeadlineMedium" />

    <!-- Venue Details Card -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardVenue"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/tvBookingDetailsTitle"
        android:layout_marginTop="24dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp">

            <TextView
                android:id="@+id/labelVenue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Venue"
                android:textAppearance="@style/TextAppearance.Material3.TitleMedium" />

            <TextView
                android:id="@+id/tvDetailVenueName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@id/labelVenue"
                android:layout_marginTop="4dp"
                android:textAppearance="@style/TextAppearance.Material3.BodyLarge"
                tools:text="Auditorium" />
        </RelativeLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- User Details Card -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardUser"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/cardVenue"
        android:layout_marginTop="16dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp">

            <TextView
                android:id="@+id/labelUser"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Requested By"
                android:textAppearance="@style/TextAppearance.Material3.TitleMedium" />

            <TextView
                android:id="@+id/tvDetailUserName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@id/labelUser"
                android:layout_marginTop="4dp"
                android:textAppearance="@style/TextAppearance.Material3.BodyLarge"
                tools:text="Tural (tural@nmims.in)" />
        </RelativeLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Time & Purpose Card -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardInfo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/cardUser"
        android:layout_marginTop="16dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp">

            <TextView
                android:id="@+id/labelDateTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Date &amp; Time"
                android:textAppearance="@style/TextAppearance.Material3.TitleMedium" />

            <TextView
                android:id="@+id/tvDetailDateTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@id/labelDateTime"
                android:layout_marginTop="4dp"
                android:textAppearance="@style/TextAppearance.Material3.BodyLarge"
                tools:text="2025-12-25, 09:00 - 11:00" />

            <TextView
                android:id="@+id/labelPurpose"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@id/tvDetailDateTime"
                android:layout_marginTop="12dp"
                android:text="Purpose / Note"
                android:textAppearance="@style/TextAppearance.Material3.TitleMedium" />

            <TextView
                android:id="@+id/tvDetailPurpose"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@id/labelPurpose"
                android:layout_marginTop="4dp"
                android:textAppearance="@style/TextAppearance.Material3.BodyLarge"
                tools:text="To conduct a workshop on Android Development for junior batch students." />
        </RelativeLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Container for buttons OR the final status text -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_marginBottom="16dp">

        <!-- Action Buttons Layout -->
        <LinearLayout
            android:id="@+id/layoutActionButtons"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnDeny"
                style="?attr/materialButtonOutlinedStyle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:layout_weight="1"
                android:text="Deny"
                android:textColor="@color/design_default_color_error"
                app:strokeColor="@color/design_default_color_error" />

            <Button
                android:id="@+id/btnApprove"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:text="Approve" />
        </LinearLayout>

        <!-- Final Status Display -->
        <TextView
            android:id="@+id/tvFinalStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:padding="16dp"
            android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
            android:visibility="gone"
            tools:text="Request has been Approved"
            tools:visibility="visible" />
    </RelativeLayout>

</RelativeLayout>
